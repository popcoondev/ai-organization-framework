      "approval_policy": "2_of_3",
      "responsibilities": [
        "schema decisions",
        "runtime design",
        "artifact contract review"
      ]
    },
    {
      "council_id": "operations-council",
      "name": "Operations Council",
      "mission": "Own verification, cadence health, and operating safety for self-hosting execution.",
      "approval_policy": "2_of_3",
      "responsibilities": [
        "verification policy",
        "cadence review",
        "operational risk"
      ]
    }
  ],
  "teams": [
    {
      "team_id": "runtime-team",
      "name": "Runtime Team",
      "mission": "Implement the AOF runtime, CLI, and artifact-writing behavior.",
