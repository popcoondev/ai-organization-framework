      "responsibilities": [
        "decision traceability",
        "contract maintenance",
        "policy modeling"
      ],
      "authority": [
        "raise governance gaps",
        "request artifact alignment"
      ],
      "deliverables": [
        "decision records",
        "policy artifacts",
        "release definitions"
      ],
      "dependencies": [
        "product-council",
        "architecture-council"
      ]
    },
    {
      "team_id": "verification-team",
      "name": "Verification Team",
      "mission": "Protect runtime correctness, smoke coverage, and benchmark evidence quality.",
      "responsibilities": [
        "test maintenance",
        "smoke verification",
        "benchmark validation"
      ],
      "authority": [
        "raise verification blockers",
        "request additional evidence"
      ],
      "deliverables": [
        "test coverage",
        "smoke scripts",
        "verification reports"
      ],
      "dependencies": [
        "operations-council",
        "runtime-team"
      ]
    }
  ],
  "roles": [
