{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-cadence-cycle.schema.json",
  "title": "AI Organization Framework Cadence Cycle",
  "type": "object",
  "required": [
    "cycle_type",
    "recorded_at",
    "timing_state",
    "cycle_state",
    "reason"
  ],
  "properties": {
    "cycle_type": {
      "type": "string",
      "enum": ["cadence-cycle"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "timing_state": {
      "type": "string",
      "enum": ["due-now", "not-due"]
    },
    "cycle_state": {
      "type": "string",
      "enum": ["deferred-not-due", "tick-executed"]
    },
    "reason": {
      "type": "string"
    },
    "tick_state": {
      "type": ["string", "null"],
      "enum": ["idle", "due-no-follow-through", "follow-through-executed", "follow-through-pending-input", null]
    },
    "follow_through_executed_action": {
      "type": ["string", "null"]
    },
    "source_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
