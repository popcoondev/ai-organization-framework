{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-anomaly-log.schema.json",
  "title": "AI Organization Framework Anomaly Log",
  "type": "object",
  "required": [
    "artifact_type",
    "recorded_at",
    "anomaly_log_id",
    "subject",
    "anomalies"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["anomaly-log"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "anomaly_log_id": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "observed_anomaly",
          "why_it_matters",
          "challenged_assumption",
          "follow_up_recommendation"
        ],
        "properties": {
          "observed_anomaly": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "challenged_assumption": {
            "type": "string"
          },
          "follow_up_recommendation": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
