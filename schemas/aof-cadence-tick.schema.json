{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-cadence-tick.schema.json",
  "title": "AI Organization Framework Cadence Tick",
  "type": "object",
  "required": [
    "tick_type",
    "recorded_at",
    "timing_state",
    "guidance_trigger_state",
    "guidance_batching_mode",
    "tick_state",
    "reason"
  ],
  "properties": {
    "tick_type": {
      "type": "string",
      "enum": ["cadence-tick"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "timing_state": {
      "type": "string",
      "enum": ["due-now", "not-due"]
    },
    "guidance_trigger_state": {
      "type": "string",
      "enum": ["idle", "follow-through-recommended"]
    },
    "guidance_batching_mode": {
      "type": "string",
      "enum": ["none", "single-action", "batched-follow-through"]
    },
    "tick_state": {
      "type": "string",
      "enum": ["idle", "due-no-follow-through", "follow-through-executed", "follow-through-pending-input"]
    },
    "reason": {
      "type": "string"
    },
    "follow_through_executed_action": {
      "type": ["string", "null"]
    },
    "source_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
