{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-retire-review.schema.json",
  "title": "AI Organization Framework Retire Candidate Review",
  "type": "object",
  "required": [
    "review_type",
    "recorded_at",
    "resolution",
    "reviewed_task_ids",
    "note"
  ],
  "properties": {
    "review_type": {
      "type": "string",
      "enum": ["retire-candidate-review"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolution": {
      "type": "string",
      "enum": ["retire", "keep-open"]
    },
    "reviewed_task_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "note": {
      "type": "string"
    },
    "source_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
