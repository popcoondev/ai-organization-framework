{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-runtime-loop-proof.schema.json",
  "title": "AI Organization Framework Runtime Loop Proof",
  "type": "object",
  "required": [
    "proof_type",
    "generated_at",
    "request",
    "routing_mode",
    "provider",
    "proof_status",
    "session_ref",
    "decision_refs",
    "allocation_plan_ref",
    "policy_evaluation_ref",
    "resource_claim_ref",
    "role_result_refs",
    "role_join_ref",
    "team_output_ref",
    "council_review_ref",
    "execution_lineage_ref",
    "learning_loop_ref",
    "phases"
  ],
  "properties": {
    "proof_type": {
      "type": "string",
      "enum": ["runtime-loop-proof"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "request": {
      "type": "string"
    },
    "routing_mode": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "proof_status": {
      "type": "string",
      "enum": ["passed"]
    },
    "session_ref": {
      "type": "string"
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allocation_plan_ref": {
      "type": "string"
    },
    "policy_evaluation_ref": {
      "type": "string"
    },
    "resource_claim_ref": {
      "type": "string"
    },
    "role_result_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "role_join_ref": {
      "type": "string"
    },
    "team_output_ref": {
      "type": "string"
    },
    "council_review_ref": {
      "type": "string"
    },
    "execution_lineage_ref": {
      "type": "string"
    },
    "learning_loop_ref": {
      "type": "string"
    },
    "phases": {
      "type": "object",
      "required": [
        "framing",
        "allocation",
        "execution",
        "review",
        "outcome",
        "next_step_recommendation"
      ],
      "properties": {
        "framing": { "type": "string" },
        "allocation": { "type": "string" },
        "execution": { "type": "string" },
        "review": { "type": "string" },
        "outcome": { "type": "string" },
        "next_step_recommendation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
