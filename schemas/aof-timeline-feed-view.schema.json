{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-timeline-feed-view.schema.json",
  "title": "AOF Timeline Feed View",
  "type": "object",
  "required": [
    "view_type",
    "entries"
  ],
  "properties": {
    "view_type": {
      "type": "string",
      "enum": ["timeline_feed"]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "at",
          "actor",
          "event_type",
          "summary",
          "rationale",
          "next",
          "refs"
        ],
        "properties": {
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "actor": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "next": {
            "type": "string"
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
