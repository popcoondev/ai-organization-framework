{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/decision-record.schema.json",
  "title": "AI Organization Framework Decision Record",
  "type": "object",
  "required": [
    "record_format_version",
    "decision_id",
    "created_at",
    "canonical_markdown_path",
    "scope",
    "stage",
    "request",
    "need",
    "intent",
    "decision_summary",
    "context_snapshot_id"
  ],
  "properties": {
    "record_format_version": { "type": "string" },
    "decision_id": { "type": "string" },
    "created_at": { "type": "string" },
    "canonical_markdown_path": { "type": "string" },
    "scope": { "type": "string" },
    "stage": { "type": "string" },
    "organization": { "type": "string" },
    "request": { "type": "string" },
    "need": { "type": "string" },
    "intent": { "type": "string" },
    "context": { "type": "string" },
    "existing_artifacts_reviewed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "background_or_prior_decisions": { "type": "string" },
    "clarifications_or_assumptions": { "type": "string" },
    "clarification_summary": { "type": "string" },
    "unresolved_ambiguity": { "type": "string" },
    "options_considered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "selected_option": { "type": "string" },
    "decision_summary": { "type": "string" },
    "governance_model": { "type": "string" },
    "execution_pattern": {
      "type": ["string", "null"],
      "enum": ["single-instance", "hybrid", "multi-agent", null]
    },
    "parallel_thread_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "thread_isolation_mode": {
      "type": ["string", "null"],
      "enum": ["full", "partial", "none", null]
    },
    "independent_seats": {
      "type": "array",
      "items": { "type": "string" }
    },
    "execution_trace_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decision_makers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "governance_rule_applied": { "type": "string" },
    "veto_used": { "type": "string" },
    "why_this_option": { "type": "string" },
    "why_other_options_were_not_selected": { "type": "string" },
    "policy_priorities_applied": { "type": "string" },
    "policy_tradeoffs_accepted": { "type": "string" },
    "actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_artifact": { "type": "string" },
    "expected_outcome": { "type": "string" },
    "completion_criteria": { "type": "string" },
    "success_criteria": { "type": "string" },
    "completion_approval_scope": { "type": "string" },
    "success_evaluation_scope": { "type": "string" },
    "forecast_required": {
      "type": "boolean"
    },
    "forecast_summary": { "type": "string" },
    "uncertainty_notes": { "type": "string" },
    "actor_performance_notes": { "type": "string" },
    "capacity_notes": { "type": "string" },
    "fit_notes": { "type": "string" },
    "protocol_thread_id": { "type": "string" },
    "change_trigger": { "type": "string" },
    "review_trigger": { "type": "string" },
    "review_date_or_condition": { "type": "string" },
    "reopen_conditions": { "type": "string" },
    "routing_mode": {
      "type": "string",
      "enum": ["fast-track", "deep-path"]
    },
    "max_retries": { "type": "integer", "minimum": 0 },
    "escalation_target": { "type": "string" },
    "context_snapshot_id": { "type": ["string", "null"] },
    "clarification_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "escalation_status": { "type": "string" },
    "escalation_summary": { "type": "string" },
    "approval_outcome_status": { "type": "string" },
    "guardian_veto_used": { "type": "string" },
    "escalation_resolution": { "type": "string" },
    "escalation_resolution_note": { "type": "string" }
  },
  "additionalProperties": false
}
