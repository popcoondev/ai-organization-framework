{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-discovery-handoff.schema.json",
  "title": "AI Organization Framework Discovery To Delivery Handoff Packet",
  "type": "object",
  "required": [
    "packet_type",
    "recorded_at",
    "handoff_id",
    "selected_need",
    "intended_user_or_segment",
    "context_summary",
    "hypothesis",
    "evidence_refs",
    "rejected_alternatives",
    "explicit_risks",
    "delivery_validation_requirements",
    "need",
    "intent",
    "context"
  ],
  "properties": {
    "packet_type": {
      "type": "string",
      "enum": ["discovery-to-delivery-handoff"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "handoff_id": {
      "type": "string"
    },
    "selected_need": {
      "type": "string"
    },
    "intended_user_or_segment": {
      "type": "string"
    },
    "context_summary": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejected_alternatives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "explicit_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "delivery_validation_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "need": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
