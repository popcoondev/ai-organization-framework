{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-team-output.schema.json",
  "title": "AI Organization Framework Team Output Packet",
  "type": "object",
  "required": [
    "packet_type",
    "recorded_at",
    "team_output_id",
    "team_id",
    "stage",
    "expected_roles",
    "received_roles",
    "missing_roles",
    "aggregate_state",
    "blocking_signals",
    "recommended_next_step",
    "joined_role_result_refs",
    "artifact_refs",
    "decision_required"
  ],
  "properties": {
    "packet_type": {
      "type": "string",
      "enum": ["team-output"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "team_output_id": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": ["framing", "planning", "execution", "approval", "review"]
    },
    "expected_roles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "received_roles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_roles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aggregate_state": {
      "type": "string",
      "enum": [
        "ready-for-council-review",
        "waiting-for-missing-roles",
        "blocked-by-signal",
        "degraded-partial-team-output"
      ]
    },
    "blocking_signals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_step": {
      "type": "string"
    },
    "joined_role_result_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decision_required": {
      "type": "boolean"
    },
    "summary": {
      "type": ["string", "null"]
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_parent_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
