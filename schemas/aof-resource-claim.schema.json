{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-resource-claim.schema.json",
  "title": "AI Organization Framework Resource Claim",
  "type": "object",
  "required": [
    "claim_type",
    "recorded_at",
    "claim_id",
    "subject_ref",
    "resource_ref",
    "claimant_role_ref",
    "claim_scope",
    "claim_status",
    "approval_policy_refs",
    "justification"
  ],
  "properties": {
    "claim_type": {
      "type": "string",
      "enum": ["resource-claim"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "claim_id": {
      "type": "string"
    },
    "subject_ref": {
      "type": "string"
    },
    "resource_ref": {
      "type": "string"
    },
    "claimant_role_ref": {
      "type": "string"
    },
    "claim_scope": {
      "type": "string"
    },
    "claim_status": {
      "type": "string",
      "enum": ["requested", "approved", "denied", "released"]
    },
    "approval_policy_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "justification": {
      "type": "string"
    },
    "allocation_plan_ref": {
      "type": ["string", "null"]
    },
    "policy_evaluation_ref": {
      "type": ["string", "null"]
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_parent_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
