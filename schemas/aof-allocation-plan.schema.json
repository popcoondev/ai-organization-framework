{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-allocation-plan.schema.json",
  "title": "AI Organization Framework Allocation Plan",
  "type": "object",
  "required": [
    "plan_type",
    "recorded_at",
    "allocation_plan_id",
    "subject_ref",
    "target_role_refs",
    "recommended_allocations",
    "policy_refs",
    "risk_notes"
  ],
  "properties": {
    "plan_type": {
      "type": "string",
      "enum": ["allocation-plan"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "allocation_plan_id": {
      "type": "string"
    },
    "subject_ref": {
      "type": "string"
    },
    "target_role_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "candidate_resource_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_allocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role_ref",
          "primary_resource_ref",
          "rationale",
          "capability_refs",
          "constraint_refs",
          "workload_state",
          "approval_required"
        ],
        "properties": {
          "role_ref": { "type": "string" },
          "primary_resource_ref": { "type": "string" },
          "supporting_resource_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": "string" },
          "capability_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "constraint_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "workload_state": {
            "type": "string",
            "enum": ["available", "limited", "reserved", "unknown"]
          },
          "approval_required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "unfilled_role_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_parent_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
