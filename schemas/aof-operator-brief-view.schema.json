{
  "type": "object",
  "required": [
    "view_type",
    "generated_at",
    "headline",
    "current_state",
    "why_now",
    "blockers",
    "next_action",
    "operator_answers"
  ],
  "properties": {
    "view_type": {
      "const": "operator_brief"
    },
    "generated_at": {
      "type": "string"
    },
    "headline": {
      "type": "string"
    },
    "current_state": {
      "type": "object",
      "required": [
        "release_version",
        "active_release_track",
        "release_definition_ref",
        "current_runtime_stage",
        "operating_goal",
        "next_value_slice",
        "primary_frontier_task"
      ],
      "properties": {
        "release_version": { "type": ["string", "null"] },
        "active_release_track": { "type": ["string", "null"] },
        "release_definition_ref": { "type": ["string", "null"] },
        "current_runtime_stage": { "type": ["string", "null"] },
        "operating_goal": { "type": ["string", "null"] },
        "next_value_slice": { "type": ["string", "null"] },
        "primary_frontier_task": {
          "type": ["object", "null"],
          "required": ["task_id", "title", "status", "updated_at", "track", "artifact_ref"],
          "properties": {
            "task_id": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string" },
            "updated_at": { "type": ["string", "null"] },
            "track": { "type": ["string", "null"] },
            "artifact_ref": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "skillful_actor_projection": {
          "type": ["object", "null"],
          "required": ["projection_ref", "projection_id", "actor", "visible_state", "proof_chain"],
          "properties": {
            "projection_ref": { "type": "string" },
            "projection_id": { "type": "string" },
            "actor": {
              "type": "object",
              "required": ["actor_ref", "role_ref", "team_ref", "character_label", "execution_mode"],
              "properties": {
                "actor_ref": { "type": ["string", "null"] },
                "role_ref": { "type": "string" },
                "team_ref": { "type": ["string", "null"] },
                "character_label": { "type": "string" },
                "execution_mode": { "type": "string" }
              },
              "additionalProperties": false
            },
            "visible_state": {
              "type": "object",
              "required": [
                "assignment_state",
                "execution_gate_state",
                "confidence_label",
                "benchmark_status",
                "council_review_needed",
                "speech_bubble",
                "current_action",
                "visible_blockers",
                "next_action"
              ],
              "properties": {
                "assignment_state": { "type": "string" },
                "execution_gate_state": { "type": "string" },
                "confidence_label": { "type": "string" },
                "benchmark_status": { "type": "string" },
                "council_review_needed": { "type": "boolean" },
                "speech_bubble": { "type": "string" },
                "current_action": { "type": "string" },
                "visible_blockers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "next_action": { "type": "string" }
              },
              "additionalProperties": false
            },
            "proof_chain": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["step", "artifact_ref", "state"],
                "properties": {
                  "step": { "type": "string" },
                  "artifact_ref": { "type": "string" },
                  "state": { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "why_now": {
      "type": "object",
      "required": ["summary", "reasons", "evidence_refs"],
      "properties": {
        "summary": { "type": ["string", "null"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary", "severity"],
        "properties": {
          "summary": { "type": "string" },
          "severity": { "type": "string" },
          "artifact_ref": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "next_action": {
      "type": "object",
      "required": ["recommended_action", "rationale", "artifact_ref"],
      "properties": {
        "recommended_action": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] },
        "artifact_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "operator_answers": {
      "type": "object",
      "required": [
        "what_is_happening_now",
        "why_this_state",
        "what_is_blocked",
        "what_should_happen_next"
      ],
      "properties": {
        "what_is_happening_now": { "type": "string" },
        "why_this_state": { "type": ["string", "null"] },
        "what_is_blocked": { "type": "string" },
        "what_should_happen_next": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
