{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-problem-statement.schema.json",
  "title": "AI Organization Framework Problem Statement",
  "type": "object",
  "required": [
    "artifact_type",
    "recorded_at",
    "problem_statement_id",
    "affected_party",
    "actual_problem",
    "why_it_matters",
    "why_now",
    "evidence_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["problem-statement"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "problem_statement_id": {
      "type": "string"
    },
    "affected_party": {
      "type": "string"
    },
    "actual_problem": {
      "type": "string"
    },
    "why_it_matters": {
      "type": "string"
    },
    "why_now": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
