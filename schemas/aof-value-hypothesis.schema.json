{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-value-hypothesis.schema.json",
  "title": "AI Organization Framework Value Hypothesis",
  "type": "object",
  "required": [
    "artifact_type",
    "recorded_at",
    "value_hypothesis_id",
    "expected_value_creation",
    "beneficiary",
    "supporting_evidence",
    "success_criteria"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["value-hypothesis"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "value_hypothesis_id": {
      "type": "string"
    },
    "expected_value_creation": {
      "type": "string"
    },
    "beneficiary": {
      "type": "string"
    },
    "supporting_evidence": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
