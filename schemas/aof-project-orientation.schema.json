{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-project-orientation.schema.json",
  "title": "AI Organization Framework Project Orientation",
  "type": "object",
  "required": [
    "orientation_type",
    "project_type",
    "domain_summary",
    "repo_boundaries",
    "protected_areas",
    "required_commands",
    "verification_entrypoints",
    "release_constraints",
    "human_owner",
    "approval_boundary",
    "command_registry_ref",
    "command_routing_summary",
    "updated_at"
  ],
  "properties": {
    "orientation_type": {
      "type": "string",
      "enum": ["project-orientation"]
    },
    "project_type": {
      "type": "string"
    },
    "domain_summary": {
      "type": "string"
    },
    "repo_boundaries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "protected_areas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification_entrypoints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "release_constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "human_owner": {
      "type": "string"
    },
    "approval_boundary": {
      "type": "string"
    },
    "command_registry_ref": {
      "type": "string"
    },
    "command_routing_summary": {
      "type": "object",
      "required": ["detail_ref", "categories", "top_commands", "runtime_flow"],
      "properties": {
        "detail_ref": {
          "type": "string"
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "purpose"],
            "properties": {
              "category": {
                "type": "string",
                "enum": ["read", "verify", "write", "execute", "observe"]
              },
              "purpose": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "top_commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "category", "purpose"],
            "properties": {
              "command": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "enum": ["read", "verify", "write", "execute", "observe"]
              },
              "purpose": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "runtime_flow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
