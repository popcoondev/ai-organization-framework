{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-organization-analytics.schema.json",
  "title": "AI Organization Framework Organization Analytics Snapshot",
  "type": "object",
  "required": [
    "snapshot_type",
    "snapshot_format_version",
    "organization_ref",
    "generated_at",
    "task_flow",
    "contract_health",
    "dependency_health",
    "escalation_health",
    "observations"
  ],
  "properties": {
    "snapshot_type": {
      "type": "string",
      "enum": ["aof-organization-analytics"]
    },
    "snapshot_format_version": {
      "type": "integer",
      "minimum": 1
    },
    "organization_ref": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "task_flow": {
      "$ref": "#/$defs/task_flow"
    },
    "contract_health": {
      "$ref": "#/$defs/contract_health"
    },
    "dependency_health": {
      "$ref": "#/$defs/dependency_health"
    },
    "escalation_health": {
      "$ref": "#/$defs/escalation_health"
    },
    "observations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "task_flow": {
      "type": "object",
      "required": ["open_count", "assigned_count", "done_count", "archived_count", "retired_count"],
      "properties": {
        "open_count": { "type": "integer", "minimum": 0 },
        "assigned_count": { "type": "integer", "minimum": 0 },
        "done_count": { "type": "integer", "minimum": 0 },
        "archived_count": { "type": "integer", "minimum": 0 },
        "retired_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "contract_health": {
      "type": "object",
      "required": ["declared_count", "artifact_present_count", "coverage_ratio"],
      "properties": {
        "declared_count": { "type": "integer", "minimum": 0 },
        "artifact_present_count": { "type": "integer", "minimum": 0 },
        "coverage_ratio": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "dependency_health": {
      "type": "object",
      "required": ["declared_count", "active_count", "bottleneck_ref_count"],
      "properties": {
        "declared_count": { "type": "integer", "minimum": 0 },
        "active_count": { "type": "integer", "minimum": 0 },
        "bottleneck_ref_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "escalation_health": {
      "type": "object",
      "required": ["decision_count", "unresolved_count"],
      "properties": {
        "decision_count": { "type": "integer", "minimum": 0 },
        "unresolved_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
