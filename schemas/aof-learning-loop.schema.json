{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-learning-loop.schema.json",
  "title": "AI Organization Framework Learning Loop Snapshot",
  "type": "object",
  "required": [
    "snapshot_type",
    "snapshot_format_version",
    "organization_ref",
    "generated_at",
    "learning_state",
    "observations"
  ],
  "properties": {
    "snapshot_type": {
      "type": "string",
      "enum": ["aof-learning-loop"]
    },
    "snapshot_format_version": {
      "type": "integer",
      "minimum": 1
    },
    "organization_ref": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "latest_outcome": {
      "type": ["object", "null"],
      "required": ["source_session_id", "report_id", "result", "observed_at", "note"],
      "properties": {
        "source_session_id": { "type": "string" },
        "report_id": { "type": "string" },
        "result": {
          "type": "string",
          "enum": ["success", "partial", "failure"]
        },
        "observed_at": { "type": "string" },
        "note": { "type": "string" },
        "signal_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "latest_self_audit": {
      "type": ["object", "null"],
      "required": ["audit_id", "recorded_at", "summary", "detected_gap", "next_action", "related_task_ids"],
      "properties": {
        "audit_id": { "type": "string" },
        "recorded_at": { "type": "string" },
        "summary": { "type": "string" },
        "detected_gap": { "type": "string" },
        "result_state": { "type": ["string", "null"] },
        "next_action": { "type": "string" },
        "related_task_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "current_next_value_slice": {
      "type": ["object", "null"],
      "required": ["content", "updated_at", "declared_complete_at"],
      "properties": {
        "content": { "type": "string" },
        "updated_at": { "type": ["string", "null"] },
        "declared_complete_at": { "type": ["string", "null"] },
        "source_session_id": { "type": ["string", "null"] },
        "source_decision_record_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "improvement_proposal": {
      "type": ["object", "null"],
      "required": ["proposal_basis", "proposed_focus", "related_task_ids", "open_task_count"],
      "properties": {
        "proposal_basis": { "type": "string" },
        "proposed_focus": { "type": "string" },
        "related_task_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_task_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "learning_state": {
      "type": "object",
      "required": [
        "has_outcome_evidence",
        "has_self_audit",
        "has_next_value_slice",
        "loop_state"
      ],
      "properties": {
        "has_outcome_evidence": { "type": "boolean" },
        "has_self_audit": { "type": "boolean" },
        "has_next_value_slice": { "type": "boolean" },
        "loop_state": {
          "type": "string",
          "enum": ["seeded", "observing", "improving", "stable"]
        }
      },
      "additionalProperties": false
    },
    "observations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
