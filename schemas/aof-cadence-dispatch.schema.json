{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-cadence-dispatch.schema.json",
  "title": "AI Organization Framework Cadence Dispatch",
  "type": "object",
  "required": [
    "dispatch_type",
    "recorded_at",
    "scheduler_state",
    "dispatch_state",
    "reason"
  ],
  "properties": {
    "dispatch_type": {
      "type": "string",
      "enum": ["cadence-dispatch"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "scheduler_state": {
      "type": "string",
      "enum": ["invoke-now", "poll-later"]
    },
    "dispatch_state": {
      "type": "string",
      "enum": ["cycle-invoked", "deferred-poll-later"]
    },
    "reason": {
      "type": "string"
    },
    "cycle_state": {
      "type": ["string", "null"],
      "enum": ["deferred-not-due", "tick-executed", null]
    },
    "tick_state": {
      "type": ["string", "null"],
      "enum": ["idle", "due-no-follow-through", "follow-through-executed", "follow-through-pending-input", null]
    },
    "follow_through_executed_action": {
      "type": ["string", "null"]
    },
    "recommended_next_check_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "recommended_next_check_after_hours": {
      "type": ["number", "integer", "null"],
      "minimum": 0
    },
    "source_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
