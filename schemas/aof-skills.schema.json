{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-skills.schema.json",
  "title": "AI Organization Framework Skills Registry",
  "type": "object",
  "required": [
    "skills_type",
    "skills_format_version",
    "organization_ref",
    "skills",
    "updated_at"
  ],
  "properties": {
    "skills_type": {
      "type": "string",
      "enum": ["aof-skills"]
    },
    "skills_format_version": {
      "type": "integer",
      "minimum": 1
    },
    "organization_ref": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "skill": {
      "type": "object",
      "required": [
        "skill_id",
        "name",
        "owner_ref",
        "version",
        "purpose",
        "applicable_role_refs",
        "required_capability_refs",
        "required_resource_refs",
        "expected_outputs"
      ],
      "properties": {
        "skill_id": { "type": "string" },
        "name": { "type": "string" },
        "owner_ref": { "type": "string" },
        "version": { "type": "string" },
        "purpose": { "type": "string" },
        "applicable_role_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_capability_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_resource_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
