{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-cadence-schedule.schema.json",
  "title": "AI Organization Framework Cadence Schedule",
  "type": "object",
  "required": [
    "schedule_type",
    "recorded_at",
    "timing_state",
    "scheduler_state",
    "reason",
    "external_scheduler_required",
    "recommended_command"
  ],
  "properties": {
    "schedule_type": {
      "type": "string",
      "enum": ["cadence-schedule"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "timing_state": {
      "type": "string",
      "enum": ["due-now", "not-due"]
    },
    "scheduler_state": {
      "type": "string",
      "enum": ["invoke-now", "poll-later"]
    },
    "reason": {
      "type": "string"
    },
    "external_scheduler_required": {
      "type": "boolean"
    },
    "recommended_command": {
      "type": "string"
    },
    "recommended_next_check_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "recommended_next_check_after_hours": {
      "type": ["number", "integer", "null"],
      "minimum": 0
    },
    "current_cycle_state": {
      "type": ["string", "null"],
      "enum": ["deferred-not-due", "tick-executed", null]
    },
    "current_tick_state": {
      "type": ["string", "null"],
      "enum": ["idle", "due-no-follow-through", "follow-through-executed", "follow-through-pending-input", null]
    },
    "stale_after_hours": {
      "type": "integer",
      "minimum": 1
    },
    "source_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
