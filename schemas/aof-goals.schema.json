{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-goals.schema.json",
  "title": "AI Organization Framework Goal Projection",
  "type": "object",
  "required": [
    "goal_type",
    "content",
    "updated_at"
  ],
  "properties": {
    "goal_type": {
      "type": "string",
      "enum": ["north-star", "operating-goal", "next-value-slice"]
    },
    "content": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "agreed_with_human": {
      "type": ["boolean", "null"]
    },
    "source_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    },
    "declared_complete_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
