{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-qif-judgment.schema.json",
  "title": "AI Organization Framework QIF Judgment",
  "type": "object",
  "required": [
    "artifact_type",
    "recorded_at",
    "judgment_id",
    "subject_ref",
    "subject_digest",
    "produced_by_ref",
    "judged_by_ref",
    "self_judgment",
    "quality_intent",
    "risk",
    "loss_boundary",
    "evidence",
    "verdict",
    "confidence",
    "uncertainty_note",
    "governance_trigger"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["qif-judgment"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "judgment_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "subject_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "produced_by_ref": {
      "type": "string",
      "minLength": 1
    },
    "judged_by_ref": {
      "type": "string",
      "minLength": 1
    },
    "self_judgment": {
      "type": "boolean"
    },
    "quality_intent": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "minLength": 1
    },
    "loss_boundary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_ref", "evidence_digest"],
        "properties": {
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          },
          "evidence_digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "evidence_role": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "conditional-pass", "fail", "needs-evidence"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "uncertainty_note": {
      "type": "string",
      "minLength": 1
    },
    "governance_trigger": {
      "type": ["object", "null"],
      "required": ["trigger_condition", "required_action"],
      "properties": {
        "trigger_condition": {
          "type": "string",
          "minLength": 1
        },
        "required_action": {
          "type": "string",
          "minLength": 1
        },
        "escalation_ref": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_parent_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "self_judgment": { "const": true }
        }
      },
      "then": {
        "properties": {
          "verdict": {
            "enum": ["conditional-pass", "fail", "needs-evidence"]
          },
          "governance_trigger": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verdict": { "enum": ["conditional-pass", "fail", "needs-evidence"] }
        }
      },
      "then": {
        "properties": {
          "governance_trigger": {
            "type": "object"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
