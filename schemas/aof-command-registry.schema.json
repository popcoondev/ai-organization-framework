{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-command-registry.schema.json",
  "title": "AOF Command Registry",
  "type": "object",
  "required": ["artifact_type", "registry_format_version", "generated_at", "detail_ref", "commands"],
  "properties": {
    "artifact_type": { "type": "string", "enum": ["command-registry"] },
    "registry_format_version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "detail_ref": { "type": "string" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "category", "purpose", "operator_path", "top_command", "inputs", "outputs", "detail_ref"],
        "properties": {
          "command": { "type": "string" },
          "category": { "type": "string", "enum": ["read", "verify", "write", "execute", "observe"] },
          "purpose": { "type": "string" },
          "operator_path": { "type": "string" },
          "top_command": { "type": "boolean" },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "detail_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
