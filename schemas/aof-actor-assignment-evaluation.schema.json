{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-actor-assignment-evaluation.schema.json",
  "title": "AI Organization Framework Actor Assignment Evaluation",
  "type": "object",
  "required": [
    "evaluation_type",
    "evaluation_format_version",
    "recorded_at",
    "evaluation_id",
    "actor_skill_packet_ref",
    "actor_skill_packet_id",
    "source_task_id",
    "source_parent_session_id",
    "assignment",
    "required_skill_refs",
    "capability_fit_summary",
    "assignment_decision",
    "missing_evidence",
    "review_required",
    "hri_projection"
  ],
  "properties": {
    "evaluation_type": {
      "type": "string",
      "enum": [
        "actor-assignment-evaluation"
      ]
    },
    "evaluation_format_version": {
      "type": "integer",
      "minimum": 1
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "evaluation_id": {
      "type": "string"
    },
    "actor_skill_packet_ref": {
      "type": "string"
    },
    "actor_skill_packet_id": {
      "type": "string"
    },
    "source_task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_parent_session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_decision_record_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "assignment": {
      "type": "object",
      "required": [
        "actor_ref",
        "role_ref",
        "team_ref",
        "execution_mode"
      ],
      "properties": {
        "actor_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "role_ref": {
          "type": "string"
        },
        "team_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_mode": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "required_skill_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "capability_fit_summary": {
      "type": "object",
      "required": [
        "strong_count",
        "sufficient_count",
        "weak_count",
        "missing_count",
        "blocked_count",
        "evidence_ref_count"
      ],
      "properties": {
        "strong_count": {
          "type": "integer",
          "minimum": 0
        },
        "sufficient_count": {
          "type": "integer",
          "minimum": 0
        },
        "weak_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "assignment_decision": {
      "type": "object",
      "required": [
        "assignment_state",
        "confidence_label",
        "rationale",
        "recommended_action"
      ],
      "properties": {
        "assignment_state": {
          "type": "string",
          "enum": [
            "selected",
            "degraded",
            "blocked",
            "escalated"
          ]
        },
        "confidence_label": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "blocked"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "recommended_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "capability_ref",
          "reason"
        ],
        "properties": {
          "capability_ref": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "review_required": {
      "type": "boolean"
    },
    "hri_projection": {
      "type": "object",
      "required": [
        "character_label",
        "speech_bubble",
        "current_action",
        "confidence_label",
        "visible_state",
        "visible_blockers",
        "next_action"
      ],
      "properties": {
        "character_label": {
          "type": "string"
        },
        "speech_bubble": {
          "type": "string"
        },
        "current_action": {
          "type": "string"
        },
        "confidence_label": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "blocked"
          ]
        },
        "visible_state": {
          "type": "string"
        },
        "visible_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
