{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-policy.schema.json",
  "title": "AI Organization Framework Policy Set",
  "type": "object",
  "required": [
    "policy_set_type",
    "policy_set_format_version",
    "organization_ref",
    "policies",
    "updated_at"
  ],
  "properties": {
    "policy_set_type": {
      "type": "string",
      "enum": ["aof-policy-set"]
    },
    "policy_set_format_version": {
      "type": "integer",
      "minimum": 1
    },
    "organization_ref": {
      "type": "string"
    },
    "policies": {
      "type": "array",
      "items": { "$ref": "#/$defs/policy" }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "policy": {
      "type": "object",
      "required": [
        "policy_id",
        "policy_kind",
        "name",
        "scope",
        "subject_refs",
        "effect",
        "owner_ref",
        "rules"
      ],
      "properties": {
        "policy_id": { "type": "string" },
        "policy_kind": {
          "type": "string",
          "enum": [
            "approval-policy",
            "escalation-policy",
            "delegation-policy",
            "access-policy",
            "review-policy",
            "retention-policy"
          ]
        },
        "name": { "type": "string" },
        "scope": { "type": "string" },
        "subject_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny", "require-approval", "require-review", "escalate"]
        },
        "owner_ref": { "type": "string" },
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exceptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
