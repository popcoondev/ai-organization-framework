{
  "type": "object",
  "required": [
    "artifact_type",
    "generated_at",
    "project_root",
    "release_version",
    "frontier_task_id",
    "benchmarks"
  ],
  "properties": {
    "artifact_type": {
      "const": "evidence-drill-down-benchmark"
    },
    "generated_at": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "release_version": {
      "type": ["string", "null"]
    },
    "frontier_task_id": {
      "type": ["string", "null"]
    },
    "benchmarks": {
      "type": "object",
      "required": ["ED-001", "ED-002", "ED-003", "ED-004", "ED-005"],
      "properties": {
        "ED-001": { "$ref": "#/$defs/benchmarkResult" },
        "ED-002": { "$ref": "#/$defs/benchmarkResult" },
        "ED-003": { "$ref": "#/$defs/benchmarkResult" },
        "ED-004": { "$ref": "#/$defs/benchmarkResult" },
        "ED-005": { "$ref": "#/$defs/benchmarkResult" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "benchmarkResult": {
      "type": "object",
      "required": ["status", "detail", "evidence"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "detail": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
