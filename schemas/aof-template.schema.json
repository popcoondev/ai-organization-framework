{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-template.schema.json",
  "title": "AI Organization Framework Root Template Manifest",
  "type": "object",
  "required": [
    "format_version",
    "organization",
    "governance",
    "policies",
    "actors",
    "workflows",
    "templates",
    "state"
  ],
  "properties": {
    "format_version": { "type": "string" },
    "organization": { "type": "string" },
    "governance": { "type": "string" },
    "policies": { "type": "string" },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "workflows": {
      "type": "object",
      "required": ["default", "registry"],
      "properties": {
        "default": { "type": "string" },
        "registry": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "templates": {
      "type": "object",
      "required": ["decision_record_markdown", "decision_record_schema"],
      "properties": {
        "decision_record_markdown": { "type": "string" },
        "decision_record_schema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "state": {
      "type": "object",
      "required": [
        "sessions",
        "decisions",
        "context_active",
        "context_summaries",
        "context_snapshots",
        "context_archive",
        "signals",
        "artifacts"
      ],
      "properties": {
        "sessions": { "type": "string" },
        "decisions": { "type": "string" },
        "context_active": { "type": "string" },
        "context_summaries": { "type": "string" },
        "context_snapshots": { "type": "string" },
        "context_archive": { "type": "string" },
        "signals": { "type": "string" },
        "artifacts": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
