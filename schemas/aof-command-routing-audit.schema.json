{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-command-routing-audit.schema.json",
  "title": "AOF Command Routing Audit",
  "type": "object",
  "required": ["ok", "artifact_type", "generated_at", "project_root", "checks", "errors"],
  "properties": {
    "ok": { "type": "boolean" },
    "artifact_type": { "type": "string", "enum": ["command-routing-audit"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "project_root": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "detail"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
