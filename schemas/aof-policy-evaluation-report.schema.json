{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-policy-evaluation-report.schema.json",
  "title": "AI Organization Framework Policy Evaluation Report",
  "type": "object",
  "required": [
    "report_type",
    "recorded_at",
    "evaluation_id",
    "subject_ref",
    "evaluation_scope",
    "policy_refs",
    "overall_outcome",
    "results",
    "recommended_actions"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "enum": ["policy-evaluation-report"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "evaluation_id": {
      "type": "string"
    },
    "subject_ref": {
      "type": "string"
    },
    "evaluation_scope": {
      "type": "string"
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "overall_outcome": {
      "type": "string",
      "enum": ["allowed", "requires-approval", "requires-review", "escalate", "denied"]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "effect",
          "outcome",
          "reason",
          "blocking"
        ],
        "properties": {
          "policy_id": { "type": "string" },
          "effect": {
            "type": "string",
            "enum": ["allow", "deny", "require-approval", "require-review", "escalate"]
          },
          "outcome": {
            "type": "string",
            "enum": ["allowed", "requires-approval", "requires-review", "escalate", "denied"]
          },
          "reason": { "type": "string" },
          "blocking": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_parent_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
