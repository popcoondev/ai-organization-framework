{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-resource-inventory.schema.json",
  "title": "AI Organization Framework Resource Inventory",
  "type": "object",
  "required": [
    "resource_inventory_type",
    "resource_inventory_format_version",
    "organization_ref",
    "resources",
    "updated_at"
  ],
  "properties": {
    "resource_inventory_type": {
      "type": "string",
      "enum": ["aof-resource-inventory"]
    },
    "resource_inventory_format_version": {
      "type": "integer",
      "minimum": 1
    },
    "organization_ref": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "resource": {
      "type": "object",
      "required": [
        "resource_id",
        "resource_type",
        "name",
        "owner_ref",
        "availability_status"
      ],
      "properties": {
        "resource_id": { "type": "string" },
        "resource_type": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "tool",
            "mcp-server",
            "repository",
            "environment",
            "budget",
            "token-envelope",
            "infrastructure"
          ]
        },
        "name": { "type": "string" },
        "owner_ref": { "type": "string" },
        "availability_status": {
          "type": "string",
          "enum": ["available", "limited", "unavailable", "reserved"]
        },
        "access_scope": { "type": "string" },
        "provided_capability_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
