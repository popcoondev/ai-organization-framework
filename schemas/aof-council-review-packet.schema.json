{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/popcoondev/ai-organization-framework/schemas/aof-council-review-packet.schema.json",
  "title": "AI Organization Framework Council Review Packet",
  "type": "object",
  "required": [
    "packet_type",
    "recorded_at",
    "review_packet_id",
    "council_id",
    "stage",
    "review_status",
    "decision_summary",
    "rationale",
    "recommendation",
    "team_output_refs",
    "role_result_refs",
    "evidence_refs",
    "follow_up_task_ids",
    "escalation_required"
  ],
  "properties": {
    "packet_type": {
      "type": "string",
      "enum": ["council-review-packet"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_packet_id": {
      "type": "string"
    },
    "council_id": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": ["framing", "planning", "execution", "approval", "review"]
    },
    "review_status": {
      "type": "string",
      "enum": ["approved", "changes-requested", "blocked", "deferred"]
    },
    "decision_summary": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "recommendation": {
      "type": "string"
    },
    "team_output_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "role_result_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "follow_up_task_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "escalation_required": {
      "type": "boolean"
    },
    "source_task_id": {
      "type": ["string", "null"]
    },
    "source_parent_session_id": {
      "type": ["string", "null"]
    },
    "source_decision_record_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
